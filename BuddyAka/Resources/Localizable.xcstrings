    "BuddyAka" : {

    },
    "BuddyAka highlights the next button. You stay in control — it never clicks for you." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka highlights the next button. You stay in control — it never clicks for you."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka подсвечивает следующую кнопку. Управление остаётся за вами — он никогда не нажимает сам."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka keyingi tugmani belgilab beradi. Boshqaruv sizda — u hech qachon o‘zi bosmaydi."
          }
        }
      }
    },
    "BuddyAka is paused until these are granted. The screen returns automatically once you're set." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka is paused until these are granted. The screen returns automatically once you're set."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka на паузе, пока не выданы разрешения. Экран вернётся автоматически, как только всё будет готово."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ushbu ruxsatlar berilmaguncha BuddyAka pauzada. Tayyor bo‘lganingizda ekran o‘zi qaytadi."
          }
        }
      }
    },
    "BuddyAka is running. Click ✨ in the menu bar anytime." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka is running. Click ✨ in the menu bar anytime."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka запущен. Нажмите ✨ в строке меню в любой момент."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka ishlamoqda. Istalgan vaqt menyu satridagi ✨ tugmasini bosing."
          }
        }
      }
    },
    "BuddyAka shows you where to click on screen and explains each step in your language." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka shows you where to click on screen and explains each step in your language."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka показывает, куда нажимать на экране, и объясняет каждый шаг на вашем языке."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuddyAka ekranda qayerga bosishni ko‘rsatadi va har bir qadamni o‘z tilingizda tushuntiradi."
          }
        }
      }
    },
